# Tu Vi La So - Environment Variables Example
PORT=8950
PRODUCTION_PORT=8900
POSTGRES_DB=tuvi
POSTGRES_USER=tuvi
POSTGRES_PASSWORD=change_me_strong_password
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
AI_PROVIDER=gemini
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
NODE_ENV=production

# Auth credentials for AI Deep Analysis
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_password

# Skip auth for local development (set to true to bypass auth)
SKIP_AUTH=false

# I Ching - đường dẫn tới file dữ liệu 64 quẻ
ICHING_DATA_PATH=./data/iching/hexagrams.json
