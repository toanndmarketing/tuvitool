    "updated_at": "2026-02-10 07:09:40"
  },
  {
    "id": 3,
    "sao_name": "Thái Dương",
    "icon": "☀️",
    "short_desc": "Dương Tinh - Mặt trời",
    "detail": "Thái Dương chủ về quang minh, chính đại, hào phóng. Sao này đại diện cho nam giới, cha, chồng. Ở cung ban ngày (Mão-Thân) thì sáng, cung đêm (Dậu-Dần) thì tối. Thái Dương sáng sủa rất tốt cho sự nghiệp và danh tiếng.",
    "good_aspects": "Rộng rãi, chính trực, có danh tiếng, tốt cho nam",
    "bad_aspects": "Khi hãm thì tổn thương cha hoặc chồng, hao tài",
    "nature": "cat",
    "sao_type": "chinh",
