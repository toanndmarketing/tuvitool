    "id": 1,
    "sao_name": "Tử Vi",
    "icon": "👑",
    "short_desc": "Đế Tinh - Vua của các sao",
    "detail": "Tử Vi là sao Đế Tinh, chủ về cao quý, quyền uy, sang trọng. Người có Tử Vi tọa Mệnh thường có phong thái đường bệ, tự tin, hay được người khác kính trọng. Tuy nhiên Tử Vi cần có bộ sao phụ tá tốt đi kèm mới phát huy hết uy lực, nếu đứng một mình thì như vua không có quần thần, khó thành đại sự.",
    "good_aspects": "Quý phái, nhiều quý nhân phù trợ, sự nghiệp thăng tiến",
    "bad_aspects": "Cô độc khi đứng một mình, dễ kiêu ngạo, chủ quan",
    "nature": "cat",
    "sao_type": "chinh",
    "created_at": "2026-02-10 07:09:40",
    "updated_at": "2026-02-10 07:09:40"
  },
  {
    "id": 2,
    "sao_name": "Thiên Cơ",
    "icon": "⚙️",
    "short_desc": "Mưu Tinh - Sao mưu trí",
    "detail": "Thiên Cơ chủ về trí tuệ, mưu lược, cơ biến. Đây là sao của người thông minh, nhanh nhạy, giỏi tính toán và thích nghi. Thiên Cơ tọa Mệnh cho người biết lo toan, có tài xoay xở.",
    "good_aspects": "Thông minh, khéo léo, tài ứng biến, phù hợp làm quân sư",
    "bad_aspects": "Hay lo lắng, đa mưu túc trí nhưng thiếu quyết đoán",
    "nature": "cat",
    "sao_type": "chinh",
